{
    "manifest_version": 3,
    "name": "SnapMark",
    "version": "1.0.0",
    "description": "Captura a aba atual do navegador, abre o editor e permite anotações antes da exportação.",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "src/popup/index.html",
        "default_title": "SnapMark"
    },
    "minimum_chrome_version": "88"
}